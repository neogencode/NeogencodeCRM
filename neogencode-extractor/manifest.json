{
  "manifest_version": 3,
  "name": "NeoGenCode Lead Extractor",
  "version": "1.0.0",
  "description": "One-click lead scraping and CRM synchronization.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.turso.io/*",
    "https://*.emailjs.com/*"
  ]
}
